# Copiar a .env y ajustar valores

# Conexión a PostgreSQL
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/gestion_alumnos

# JWT
SECRET_KEY=cambiar-esta-clave-en-produccion-usar-string-aleatorio-largo
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS — orígenes permitidos del frontend (separados por coma)
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# Reglas de negocio
DIAS_PROXIMO_VENCER=5
